# marketing-automation environment variables
# Copy this to .env and fill in real values. Never commit .env.

# Infragistics AI Agent Gateway — PAT token
# Format: mcp-<kid>.<secret>
# Get from: https://ai-agent-gateway.infragistics.com
GATEWAY_TOKEN=

# Gateway base URL (default is production — override for local dev)
# GATEWAY_BASE_URL=https://ai-agent-gateway.infragistics.com
